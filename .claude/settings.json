{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(pnpm install)",
      "Bash(pnpm install:*)",
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Bash(pnpm preview)",
      "Bash(pnpm test)",
      "Bash(pnpm test:*)",
      "Bash(pnpm lint)",
      "Bash(pnpm tsc)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm dlx:*)",
      "Bash(pnpm run:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git show)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote:*)",
      "Bash(git config --get:*)",
      "Bash(ls)",
      "Bash(ls:*)",
      "Bash(find . -type:*)",
      "Bash(find src:*)",
      "Bash(find docs:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(cat package.json)",
      "Bash(cat tsconfig.json)",
      "Bash(cat tsconfig.app.json)",
      "Bash(cat vite.config.ts)",
      "Bash(cat eslint.config.js)"
    ],
    "deny": [
      "Bash(curl *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  }
}
